[
  {
    "name": "theme_info",
    "theme_name": "Modatrend",
    "theme_version": "0.1.0",
    "theme_author": "Modatrend",
    "theme_documentation_url": "https://help.shopify.com/manual/online-store/themes",
    "theme_support_url": "https://support.shopify.com/"
  },
  {
    "name": "t:general.typography",
    "settings": [
      {
        "type": "header",
        "content": "t:general.fonts"
      },
      {
        "type": "font_picker",
        "id": "type_primary_font",
        "default": "quicksand_n4",
        "label": "t:general.primary"
      }
    ]
  },
  {
    "name": "t:general.layout",
    "settings": [
      {
        "type": "select",
        "id": "max_page_width",
        "label": "t:labels.page_width",
        "options": [
          {
            "value": "110rem",
            "label": "t:options.page_width.narrow"
          },
          {
            "value": "125rem",
            "label": "t:options.page_width.standard"
          },
          {
            "value": "144rem",
            "label": "t:options.page_width.wide"
          }
        ],
        "default": "125rem"
      },
      {
        "type": "range",
        "id": "min_page_margin",
        "min": 10,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "t:labels.page_margin",
        "default": 16
      }
    ]
  },
  {
    "name": "t:general.whatsapp",
    "settings": [
      {
        "type": "text",
        "id": "whatsapp_number",
        "label": "t:labels.whatsapp_number",
        "info": "t:info.whatsapp_number"
      },
      {
        "type": "text",
        "id": "whatsapp_display",
        "label": "t:labels.whatsapp_display"
      },
      {
        "type": "checkbox",
        "id": "whatsapp_fab",
        "label": "t:labels.whatsapp_fab",
        "default": true
      }
    ]
  },
  {
    "name": "t:general.promotions",
    "settings": [
      {
        "type": "range",
        "id": "extra_discount_percent",
        "min": 0,
        "max": 50,
        "step": 1,
        "unit": "%",
        "label": "t:labels.extra_discount_percent",
        "info": "t:info.extra_discount_percent",
        "default": 10
      }
    ]
  },
  {
    "name": "t:general.colors",
    "settings": [
      {
        "type": "color",
        "id": "background_color",
        "default": "#FFFFFF",
        "label": "t:labels.background"
      },
      {
        "type": "color",
        "id": "foreground_color",
        "default": "#111111",
        "label": "t:labels.foreground"
      },
      {
        "type": "color",
        "id": "accent_color",
        "default": "#E1137D",
        "label": "t:labels.accent"
      },
      {
        "type": "color",
        "id": "muted_color",
        "default": "#959595",
        "label": "t:labels.muted"
      },
      {
        "type": "color",
        "id": "border_color",
        "default": "#E1E1E1",
        "label": "t:labels.border"
      },
      {
        "type": "color",
        "id": "surface_color",
        "default": "#F5F5F5",
        "label": "t:labels.surface"
      },
      {
        "type": "color",
        "id": "shipping_badge_color",
        "default": "#3DBE29",
        "label": "t:labels.shipping_badge"
      },
      {
        "type": "range",
        "id": "input_corner_radius",
        "min": 0,
        "max": 10,
        "step": 1,
        "unit": "px",
        "label": "t:labels.input_corner_radius",
        "default": 0
      }
    ]
  }
]
