{% doc %}
  Floating WhatsApp order button (bottom-left, green circle), like the
  source site. Uses the theme's global `whatsapp_number` setting; on
  product pages the prefilled message includes the product URL.

  Renders nothing when the setting is empty or the FAB is disabled.

  @example
  {% render 'whatsapp-fab' %}
{% enddoc %}

{%- if settings.whatsapp_fab and settings.whatsapp_number != blank -%}
  {%- liquid
    assign message = 'general.whatsapp_message' | t
    if template.name == 'product' and product
      assign page_url = request.origin | append: product.url
      assign message = page_url | append: ' ' | append: message
    endif
  -%}
  <a
    class="whatsapp-fab"
    href="https://api.whatsapp.com/send?phone={{ settings.whatsapp_number }}&text={{ message | url_encode }}"
    target="_blank"
    rel="noopener"
    aria-label="{{ 'general.whatsapp_label' | t }}"
  >
    <svg viewBox="0 0 24 24" width="26" height="26" fill="currentColor" aria-hidden="true" focusable="false">
      <path d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5-1.3A10 10 0 1 0 12 2zm5.3 14.1c-.2.6-1.2 1.2-1.7 1.2-.4.1-1 .1-1.6-.1a14 14 0 0 1-1.5-.5 11.5 11.5 0 0 1-4.4-3.9 5 5 0 0 1-1-2.7c0-1.3.7-1.9 1-2.2a1 1 0 0 1 .7-.3h.5c.2 0 .4 0 .6.4l.9 2.1c0 .2.1.3 0 .5l-.3.5-.5.5c-.1.2-.3.3-.1.6a8.7 8.7 0 0 0 1.6 2 8 8 0 0 0 2.3 1.4c.3.2.5.1.6 0l.7-.8c.2-.3.4-.2.6-.1l1.9.9c.2.1.4.2.4.3 0 .2 0 .7-.2 1.2z"></path>
    </svg>
  </a>
{%- endif -%}

{% stylesheet %}
  .whatsapp-fab {
    position: fixed;
    bottom: var(--space-md);
    left: var(--space-md);
    z-index: 60;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 5.2rem;
    height: 5.2rem;
    border-radius: 50%;
    background-color: #25d366;
    color: #ffffff;
    box-shadow: 0 4px 12px rgb(0 0 0 / 20%);
    transition: transform var(--transition-base);
  }

  .whatsapp-fab:hover {
    color: #ffffff;
    transform: scale(1.06);
  }
{% endstylesheet %}
