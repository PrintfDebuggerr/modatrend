{% doc %}
  Renders a Modatrend product card: flat/square media on a light surface,
  fast-shipping ribbon, product-code pill, favorite toggle, quick size links
  on hover (desktop), title and pricing.

  Behavior notes:
  - The fast-shipping ribbon shows when the product is tagged `24-saat-kargo`.
  - Quick sizes render one link per variant (hidden for single-variant
    products) and deep-link to the product page with the variant selected.
  - Favorites persist to localStorage under `modatrend:favorites`.

  @param {product} product - The product to render
  @param {boolean} [show_quick_sizes] - Show hover quick-size links (default: true)

  @example
  {% render 'product-card', product: product %}
{% enddoc %}

{% liquid
  assign show_quick_sizes = show_quick_sizes | default: true, allow_false: true
  assign sku = product.selected_or_first_available_variant.sku
  assign model_code = product.metafields.custom.model_code | default: sku

  assign card_price = product.selected_or_first_available_variant.price | default: product.price
  assign card_compare = product.selected_or_first_available_variant.compare_at_price | default: product.compare_at_price
  assign discount_percent = 0
  if card_compare > card_price
    assign discount_percent = card_compare | minus: card_price | times: 100 | divided_by: card_compare
  endif

  assign show_sizes = false
  if show_quick_sizes and product.available
    unless product.has_only_default_variant
      assign show_sizes = true
    endunless
  endif
%}

<article class="product-card">
  <div class="product-card__media">
    <a href="{{ product.url }}" class="product-card__media-link" tabindex="-1" aria-hidden="true">
      {%- if product.featured_image -%}
        {{
          product.featured_image
          | image_url: width: 900
          | image_tag:
            widths: '300, 450, 600, 900',
            sizes: '(min-width: 750px) 25vw, 50vw',
            class: 'product-card__image',
            loading: 'lazy'
        }}
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag: 'product-card__image product-card__image--placeholder' }}
      {%- endif -%}
    </a>

    {%- if product.tags contains '24-saat-kargo' -%}
      <span class="product-card__ribbon">
        <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor" aria-hidden="true" focusable="false"><path d="M1 5h13v11H1zM14 8h4l3 3v5h-7zM6 19a2 2 0 1 0 0-.01M17.5 19a2 2 0 1 0 0-.01"></path></svg>
        {{ 'products.card.fast_shipping' | t }}
      </span>
    {%- endif -%}

    {%- if discount_percent > 0 -%}
      <span class="product-card__discount" aria-hidden="true">
        <strong>{{ 'products.price.badge_percent' | t: percent: discount_percent }}</strong>
        <span>{{ 'products.price.discount_label' | t }}</span>
      </span>
    {%- endif -%}

    {%- if model_code != blank -%}
      <span class="product-card__code">
        <span>{{ 'products.card.product_code' | t }}</span>
        <strong>{{ model_code }}</strong>
      </span>
    {%- endif -%}

    <button
      type="button"
      class="product-card__favorite"
      data-favorite-button
      data-product-handle="{{ product.handle }}"
      aria-label="{{ 'products.card.add_to_favorites' | t }}"
      aria-pressed="false"
    >
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
        <path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.6l-1-1a5.5 5.5 0 0 0-7.8 7.8l1 1L12 21.2l7.8-7.8 1-1a5.5 5.5 0 0 0 0-7.8z"></path>
      </svg>
    </button>

    {%- unless product.available -%}
      <span class="product-card__soldout">{{ 'products.card.sold_out' | t }}</span>
    {%- endunless -%}

    {%- if show_sizes -%}
      <ul class="product-card__sizes" aria-label="{{ 'products.card.quick_sizes' | t }}">
        {%- for variant in product.variants limit: 8 -%}
          <li>
            {%- if variant.available -%}
              <a class="product-card__size" href="{{ product.url }}?variant={{ variant.id }}">{{ variant.title }}</a>
            {%- else -%}
              <span class="product-card__size product-card__size--disabled" aria-disabled="true">{{ variant.title }}</span>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>

  <div class="product-card__info">
    <h3 class="product-card__title">
      <a href="{{ product.url }}">{{ product.title }}</a>
    </h3>
    {% render 'price', product: product %}
  </div>
</article>

{% render 'favorites-toggle' %}

{% stylesheet %}
  .product-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    border-radius: var(--card-radius);
  }

  .product-card__media {
    position: relative;
    overflow: hidden;
    background-color: var(--color-surface);
  }

  .product-card__media-link {
    display: block;
  }

  .product-card__image {
    width: 100%;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    transition: transform var(--transition-base);
  }

  .product-card:hover .product-card__image {
    transform: scale(1.03);
  }

  .product-card__ribbon {
    position: absolute;
    top: var(--space-xs);
    left: 0;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2xs);
    max-width: 70%;
    overflow: hidden;
    padding: var(--space-2xs) var(--space-sm);
    border-radius: 0 999px 999px 0;
    background-color: var(--color-ship-badge);
    color: var(--color-accent-contrast);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    white-space: nowrap;
    text-overflow: ellipsis;
  }

  .product-card__discount {
    position: absolute;
    top: calc(var(--space-xs) + 3.2rem);
    left: var(--space-xs);
    z-index: 2;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    padding: var(--space-2xs) var(--space-xs);
    border-radius: 0.4rem;
    background-color: var(--color-accent);
    color: var(--color-accent-contrast);
    font-size: var(--font-size-xs);
    line-height: 1.2;
    text-transform: uppercase;
  }

  .product-card__discount strong {
    font-size: var(--font-size-md);
  }

  .product-card__media:not(:has(.product-card__ribbon)) .product-card__discount {
    top: var(--space-xs);
  }

  .product-card__code {
    position: absolute;
    top: var(--space-xs);
    right: var(--space-xs);
    z-index: 2;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    max-width: 45%;
    overflow: hidden;
    padding: var(--space-2xs) var(--space-sm);
    border-radius: 0.8rem;
    background-color: color-mix(in srgb, var(--color-muted) 75%, transparent);
    color: var(--color-accent-contrast);
    font-size: var(--font-size-xs);
    line-height: 1.25;
    text-align: center;
    white-space: nowrap;
    text-overflow: ellipsis;
  }

  .product-card__media:has(.product-card__ribbon) .product-card__code {
    top: calc(var(--space-xs) + 0.2rem);
  }

  .product-card__favorite {
    position: absolute;
    bottom: var(--space-xs);
    right: var(--space-xs);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.6rem;
    height: 3.6rem;
    padding: 0;
    border: 0;
    background: transparent;
    color: var(--color-accent);
    cursor: pointer;
  }

  .product-card__favorite.is-active svg {
    fill: currentcolor;
  }

  .product-card__soldout {
    position: absolute;
    bottom: var(--space-xs);
    left: var(--space-xs);
    padding: var(--space-2xs) var(--space-xs);
    background-color: var(--color-foreground);
    color: var(--color-background);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
  }

  .product-card__sizes {
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    display: none;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-2xs);
    margin: 0;
    padding: var(--space-xs);
    list-style: none;
    background-color: color-mix(in srgb, var(--color-background) 92%, transparent);
  }

  @media (hover: hover) and (min-width: 750px) {
    .product-card:is(:hover, :focus-within) .product-card__sizes {
      display: flex;
    }
  }

  .product-card__size {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 3.6rem;
    height: 3.6rem;
    padding: 0 var(--space-2xs);
    border: 1px solid var(--color-border);
    background-color: var(--color-background);
    font-size: var(--font-size-sm);
    transition: border-color var(--transition-base);
  }

  a.product-card__size:hover {
    border-color: var(--color-accent);
    color: var(--color-foreground);
  }

  .product-card__size--disabled {
    color: var(--color-muted);
    text-decoration: line-through;
    cursor: not-allowed;
  }

  .product-card__info {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    text-align: center;
  }

  .product-card__title {
    margin: 0;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-normal);
    line-height: var(--line-height-base);
  }

  .product-card__title a {
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    overflow: hidden;
  }
{% endstylesheet %}

