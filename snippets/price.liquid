{% doc %}
  Renders product pricing in the Modatrend card style: centered magenta
  sale price with the struck-through compare-at price beneath it, and an
  optional rounded "extra discount" promo bar computed from the theme's
  `extra_discount_percent` setting.

  The percent-discount badge is rendered by the product card as a media
  overlay, not here. The extra-discount bar is display-only — pair it
  with a matching automatic discount in the Shopify admin.

  @param {product} product - The product to render pricing for
  @param {boolean} [show_extra] - Render the extra-discount bar (default: true)

  @example
  {% render 'price', product: product %}
  {% render 'price', product: product, show_extra: false %}
{% enddoc %}

{% liquid
  assign show_extra = show_extra | default: true, allow_false: true

  assign variant = product.selected_or_first_available_variant
  assign price = variant.price | default: product.price
  assign compare_at = variant.compare_at_price | default: product.compare_at_price

  assign on_sale = false
  if compare_at > price
    assign on_sale = true
  endif

  assign extra_percent = settings.extra_discount_percent | default: 0
  if extra_percent > 0
    assign extra_multiplier = 100 | minus: extra_percent
    assign extra_price = price | times: extra_multiplier | divided_by: 100 | money
  endif
%}

<div class="price{% if on_sale %} price--on-sale{% endif %}">
  <div class="price__amounts">
    <span class="price__current">
      <span class="visually-hidden">{{ 'products.price.sale_price' | t }}</span>
      {{ price | money }}
    </span>
    {%- if on_sale -%}
      <s class="price__compare">
        <span class="visually-hidden">{{ 'products.price.regular_price' | t }}</span>
        {{ compare_at | money }}
      </s>
    {%- endif -%}
  </div>
  {%- if show_extra and extra_percent > 0 -%}
    <p class="price__extra">
      {{ 'products.price.extra_discount_html' | t: percent: extra_percent, price: extra_price }}
    </p>
  {%- endif -%}
</div>

{% stylesheet %}
  .price {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .price__amounts {
    display: flex;
    flex-direction: column;
    align-items: center;
    line-height: 1.2;
  }

  .price__current {
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-bold);
    color: var(--color-foreground);
  }

  .price--on-sale .price__current {
    color: var(--color-accent);
  }

  .price__compare {
    font-size: var(--font-size-xs);
    color: var(--color-muted);
  }

  .price__extra {
    display: block;
    padding: var(--space-2xs) var(--space-xs);
    border-radius: 0.6rem;
    background-color: var(--color-accent);
    color: var(--color-accent-contrast);
    font-size: var(--font-size-sm);
    text-align: center;
  }

  .price__extra strong {
    font-size: var(--font-size-md);
  }
{% endstylesheet %}
