{% doc %}
  Renders product pricing in the Modatrend style: sale price with a square
  percent-discount badge, struck-through compare-at price, and an optional
  "extra discount" promo bar computed from the theme's
  `extra_discount_percent` setting.

  The extra-discount bar is display-only. Pair it with a matching automatic
  discount in the Shopify admin so the price actually applies at checkout.

  @param {product} product - The product to render pricing for
  @param {boolean} [show_badge] - Render the percent-discount badge (default: true)
  @param {boolean} [show_extra] - Render the extra-discount bar (default: true)

  @example
  {% render 'price', product: product %}
  {% render 'price', product: product, show_extra: false %}
{% enddoc %}

{% liquid
  assign show_badge = show_badge | default: true, allow_false: true
  assign show_extra = show_extra | default: true, allow_false: true

  assign variant = product.selected_or_first_available_variant
  assign price = variant.price | default: product.price
  assign compare_at = variant.compare_at_price | default: product.compare_at_price

  assign on_sale = false
  if compare_at > price
    assign on_sale = true
    assign discount_percent = compare_at | minus: price | times: 100 | divided_by: compare_at
  endif

  assign extra_percent = settings.extra_discount_percent | default: 0
  if extra_percent > 0
    assign extra_multiplier = 100 | minus: extra_percent
    assign extra_price = price | times: extra_multiplier | divided_by: 100 | money
  endif
%}

<div class="price{% if on_sale %} price--on-sale{% endif %}">
  <div class="price__main">
    {%- if show_badge and on_sale -%}
      <span class="price__badge" aria-hidden="true">
        <strong>{{ 'products.price.badge_percent' | t: percent: discount_percent }}</strong>
        <span>{{ 'products.price.discount_label' | t }}</span>
      </span>
    {%- endif -%}
    <span class="price__amounts">
      <span class="price__current">
        <span class="visually-hidden">{{ 'products.price.sale_price' | t }}</span>
        {{ price | money }}
      </span>
      {%- if on_sale -%}
        <s class="price__compare">
          <span class="visually-hidden">{{ 'products.price.regular_price' | t }}</span>
          {{ compare_at | money }}
        </s>
      {%- endif -%}
    </span>
  </div>
  {%- if show_extra and extra_percent > 0 -%}
    <p class="price__extra">
      {{ 'products.price.extra_discount_html' | t: percent: extra_percent, price: extra_price }}
    </p>
  {%- endif -%}
</div>

{% stylesheet %}
  .price {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .price__main {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-xs);
  }

  .price__badge {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--space-2xs) var(--space-xs);
    background-color: var(--color-accent);
    color: var(--color-accent-contrast);
    line-height: 1.1;
  }

  .price__badge > strong {
    font-size: var(--font-size-md);
    font-weight: var(--font-weight-bold);
  }

  .price__badge > span {
    font-size: var(--font-size-xs);
  }

  .price__amounts {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .price__current {
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-bold);
    color: var(--color-foreground);
  }

  .price--on-sale .price__current {
    color: var(--color-accent);
  }

  .price__compare {
    font-size: var(--font-size-xs);
    color: var(--color-muted);
  }

  .price__extra {
    display: block;
    padding: var(--space-2xs) var(--space-xs);
    background-color: var(--color-accent);
    color: var(--color-accent-contrast);
    font-size: var(--font-size-sm);
    text-align: center;
  }

  .price__extra strong {
    font-size: var(--font-size-md);
  }
{% endstylesheet %}
