{% comment %}
  Modatrend product page (PDP), matched to the source (Ticimax) layout.

  Top bar: multi-level breadcrumb (collections sorted broad → narrow) with a
  "back to previous page" link on the right.

  Two-column layout on desktop: media gallery (thumbnail switcher, round
  product-code overlay) on the left; buy column on the right — a surface
  card holding title + SKU, struck-through compare price, percent-discount
  badge next to the sale price, an optional installment line and the
  extra-discount pill; then payment-options link, linked color siblings
  ("Renkler", from the `custom.color_group` product-list metafield), size
  chart link, square size selector with a diagonal strike on sold-out
  sizes, quantity stepper, add to cart, favorite toggle, and a boxed
  accordion group (description + custom blocks).

  On mobile the gallery becomes a horizontal scroll-snap carousel.
{% endcomment %}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign sku = current_variant.sku
  assign crumb_collection = collection | default: product.collections.first
  assign color_group = product.metafields.custom.color_group.value
  assign model_code = product.metafields.custom.model_code | default: sku

  assign price = current_variant.price | default: product.price
  assign compare_at = current_variant.compare_at_price | default: product.compare_at_price
  assign on_sale = false
  if compare_at > price
    assign on_sale = true
    assign discount_percent = compare_at | minus: price | times: 100 | divided_by: compare_at
  endif

  assign extra_percent = settings.extra_discount_percent | default: 0
  if extra_percent > 0
    assign extra_multiplier = 100 | minus: extra_percent
    assign extra_price = price | times: extra_multiplier | divided_by: 100 | money
  endif

  assign installment_count = section.settings.installment_count | default: 0
  if installment_count > 1
    assign installment_amount = price | divided_by: installment_count | money
  endif
-%}

<nav class="pdp-breadcrumb" aria-label="breadcrumb">
  <div class="pdp-breadcrumb__trail">
    <a href="{{ routes.root_url }}">{{ 'general.breadcrumb_home' | t }}</a>
    {%- assign crumb_collections = product.collections | sort: 'products_count' | reverse -%}
    {%- for crumb in crumb_collections limit: 3 -%}
      {%- unless crumb.handle == 'frontpage' or crumb.handle == 'all' -%}
        <span aria-hidden="true">&gt;</span>
        <a href="{{ crumb.url }}">{{ crumb.title }}</a>
      {%- endunless -%}
    {%- endfor -%}
    <span aria-hidden="true">&gt;</span>
    <span aria-current="page">{{ product.title }}</span>
  </div>
  <a
    class="pdp-breadcrumb__back"
    href="{{ crumb_collection.url | default: routes.root_url }}"
    data-back-link
  >
    ‹ {{ 'products.product.back_to_previous' | t }}
  </a>
</nav>

<div class="pdp">
  <div class="pdp__gallery">
    <div class="pdp__media">
      {%- for media in product.media -%}
        {%- liquid
          if forloop.first
            assign img_loading = 'eager'
          else
            assign img_loading = 'lazy'
          endif
        -%}
        <div
          class="pdp__slide{% if forloop.first %} is-active{% endif %}"
          data-gallery-slide="{{ forloop.index0 }}"
        >
          {{
            media.preview_image
            | image_url: width: 1100
            | image_tag:
              widths: '400, 600, 900, 1100',
              sizes: '(min-width: 750px) 44vw, 100vw',
              class: 'pdp__image',
              loading: img_loading
          }}
        </div>
      {%- else -%}
        <div class="pdp__slide is-active">
          {{ 'product-1' | placeholder_svg_tag: 'pdp__image pdp__image--placeholder' }}
        </div>
      {%- endfor -%}

      {%- if on_sale -%}
        <span class="pdp__discount-badge" aria-hidden="true">
          <strong>{{ 'products.price.badge_percent' | t: percent: discount_percent }}</strong>
          <span>{{ 'products.price.discount_label' | t }}</span>
        </span>
      {%- endif -%}

      {%- if model_code != blank -%}
        <span class="pdp__code">
          <span>{{ 'products.card.product_code' | t }}</span>
          <strong>{{ model_code }}</strong>
        </span>
      {%- endif -%}
    </div>

    {%- if product.media.size > 1 -%}
      <div class="pdp__thumbs">
        {%- for media in product.media -%}
          <button
            type="button"
            class="pdp__thumb{% if forloop.first %} is-active{% endif %}"
            data-gallery-thumb="{{ forloop.index0 }}"
            aria-label="{{ 'products.product.view_image' | t: index: forloop.index }}"
          >
            {{ media.preview_image | image_url: width: 200 | image_tag: loading: 'lazy' }}
          </button>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>

  <div class="pdp__info">
    <div class="pdp__card">
      <h1 class="pdp__title">{{ product.title }}</h1>
      {%- if sku != blank -%}
        <p class="pdp__sku">{{ 'products.product.sku_label' | t }} ({{ sku }})</p>
      {%- endif -%}

      <div class="pdp__price{% if on_sale %} pdp__price--on-sale{% endif %}">
        {%- if on_sale -%}
          <s class="pdp__price-compare">
            <span class="visually-hidden">{{ 'products.price.regular_price' | t }}</span>
            {{ compare_at | money }}
          </s>
        {%- endif -%}

        <div class="pdp__price-row">
          {%- if on_sale -%}
            <span class="pdp__price-badge" aria-hidden="true">
              <strong>{{ 'products.price.badge_percent' | t: percent: discount_percent }}</strong>
              <span>{{ 'products.price.discount_label' | t }}</span>
            </span>
          {%- endif -%}
          <span class="pdp__price-current">
            <span class="visually-hidden">{{ 'products.price.sale_price' | t }}</span>
            {{ price | money }}
          </span>
        </div>

        {%- if installment_count > 1 -%}
          <p class="pdp__installments">
            {{ 'products.product.installments_from_html' | t: amount: installment_amount }}
          </p>
        {%- endif -%}

        {%- if extra_percent > 0 -%}
          <p class="pdp__extra">
            {{ 'products.price.extra_discount_html' | t: percent: extra_percent, price: extra_price }}
          </p>
        {%- endif -%}
      </div>
    </div>

    {%- if section.settings.payment_options_page != blank -%}
      <a class="pdp__side-link" href="{{ section.settings.payment_options_page.url }}">
        {{- 'products.product.payment_options' | t -}}
      </a>
    {%- endif -%}

    {%- if color_group -%}
      <div class="pdp__colors">
        <p class="pdp__label">{{ 'products.product.colors' | t }}</p>
        <ul class="pdp__color-list" role="list">
          {%- for sibling in color_group -%}
            <li>
              <a
                href="{{ sibling.url }}"
                class="pdp__color{% if sibling.id == product.id %} is-current{% endif %}"
                {% if sibling.id == product.id %}aria-current="page"{% endif %}
              >
                {{ sibling.featured_image | image_url: width: 120 | image_tag: alt: sibling.title, loading: 'lazy' }}
              </a>
            </li>
          {%- endfor -%}
        </ul>
      </div>
    {%- endif -%}

    {% form 'product', product, id: 'PdpProductForm', class: 'pdp__form' %}
      {%- if product.has_only_default_variant -%}
        <input type="hidden" name="id" value="{{ current_variant.id }}">
      {%- elsif product.options.size == 1 -%}
        {%- if section.settings.size_chart_page != blank -%}
          <a class="pdp__side-link pdp__side-link--divided" href="{{ section.settings.size_chart_page.url }}">
            {{- 'products.product.size_chart' | t -}}
          </a>
        {%- endif -%}
        <fieldset class="pdp__sizes">
          <legend class="pdp__label">{{ product.options_with_values.first.name }}</legend>
          <div class="pdp__size-grid">
            {%- for variant in product.variants -%}
              <label class="pdp__size{% unless variant.available %} pdp__size--disabled{% endunless %}">
                <input
                  type="radio"
                  name="id"
                  value="{{ variant.id }}"
                  {% if variant.id == current_variant.id %}checked{% endif %}
                  {% unless variant.available %}disabled{% endunless %}
                >
                <span>{{ variant.title }}</span>
              </label>
            {%- endfor -%}
          </div>
        </fieldset>
      {%- else -%}
        <label class="pdp__label" for="VariantSelect">{{ 'products.product.select_variant' | t }}</label>
        <select id="VariantSelect" class="pdp__variant-select" name="id">
          {%- for variant in product.variants -%}
            <option
              value="{{ variant.id }}"
              {% if variant.id == current_variant.id %}selected{% endif %}
              {% unless variant.available %}disabled{% endunless %}
            >
              {{ variant.title }}
            </option>
          {%- endfor -%}
        </select>
      {%- endif -%}

      <div class="pdp__buy">
        <div class="pdp__qty">
          <button type="button" data-qty-change="-1" aria-label="{{ 'products.product.decrease_qty' | t }}">−</button>
          <input
            type="number"
            name="quantity"
            value="1"
            min="1"
            inputmode="numeric"
            aria-label="{{ 'products.product.quantity' | t }}"
            data-qty-input
          >
          <button type="button" data-qty-change="1" aria-label="{{ 'products.product.increase_qty' | t }}">+</button>
        </div>

        <button
          type="submit"
          name="add"
          class="button pdp__submit"
          {% unless product.available %}disabled{% endunless %}
        >
          {%- if product.available -%}
            {{ 'products.product.add_to_cart' | t }}
          {%- else -%}
            {{ 'products.card.sold_out' | t }}
          {%- endif -%}
        </button>
      </div>
    {% endform %}

    <button
      type="button"
      class="pdp__favorite"
      data-favorite-button
      data-product-handle="{{ product.handle }}"
      aria-pressed="false"
    >
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
        <path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.6l-1-1a5.5 5.5 0 0 0-7.8 7.8l1 1L12 21.2l7.8-7.8 1-1a5.5 5.5 0 0 0 0-7.8z"></path>
      </svg>
      {{ 'products.card.add_to_favorites' | t }}
    </button>

    <div class="pdp__details">
      {%- if product.description != blank -%}
        <details class="pdp__accordion" open>
          <summary>{{ 'products.product.description_title' | t }}</summary>
          <div class="pdp__accordion-content pdp__accordion-content--scroll">{{ product.description }}</div>
        </details>
      {%- endif -%}

      {%- for block in section.blocks -%}
        {%- if block.settings.title != blank and block.settings.content != blank -%}
          <details class="pdp__accordion" {{ block.shopify_attributes }}>
            <summary>{{ block.settings.title }}</summary>
            <div class="pdp__accordion-content">{{ block.settings.content }}</div>
          </details>
        {%- endif -%}
      {%- endfor -%}

      {%- comment -%} Reviews row (matches source layout) {%- endcomment -%}
      {%- assign review_count = product.metafields.reviews.rating_count.value | default: 0 -%}
      <details class="pdp__accordion">
        <summary>{{ 'products.product.reviews_title' | t }} ({{ review_count }})</summary>
        <div class="pdp__accordion-content">
          <p class="pdp__empty-note">{{ 'products.product.no_reviews' | t }}</p>
        </div>
      </details>

      {%- comment -%} Product suggestions row {%- endcomment -%}
      <details class="pdp__accordion">
        <summary>{{ 'products.product.suggestions_title' | t }}</summary>
        <div class="pdp__accordion-content">
          {%- assign shown = 0 -%}
          {%- if crumb_collection and crumb_collection.products.size > 0 -%}
            <div class="pdp__suggests">
              {%- for item in crumb_collection.products limit: 10 -%}
                {%- if item.id != product.id and shown < 6 -%}
                  {%- assign shown = shown | plus: 1 -%}
                  <a class="pdp__suggest" href="{{ item.url }}">
                    <span class="pdp__suggest-media">
                      {{ item.featured_image | image_url: width: 220 | image_tag: loading: 'lazy', alt: item.title }}
                    </span>
                    <span class="pdp__suggest-title">{{ item.title }}</span>
                    <span class="pdp__suggest-price">{{ item.price | money }}</span>
                  </a>
                {%- endif -%}
              {%- endfor -%}
            </div>
          {%- endif -%}
          {%- if shown == 0 -%}
            <p class="pdp__empty-note">{{ 'products.product.no_suggestions' | t }}</p>
          {%- endif -%}
        </div>
      </details>
    </div>
  </div>
</div>

<div class="pdp__sticky" data-pdp-sticky>
  <div class="pdp__sticky-price{% if on_sale %} pdp__sticky-price--on-sale{% endif %}">
    {%- if on_sale -%}
      <s>{{ compare_at | money }}</s>
    {%- endif -%}
    <span class="pdp__sticky-current">{{ price | money }}</span>
  </div>
  <button
    type="submit"
    form="PdpProductForm"
    class="button pdp__sticky-add"
    {% unless product.available %}disabled{% endunless %}
  >
    {%- if product.available -%}
      {{ 'products.product.add_to_cart' | t }}
    {%- else -%}
      {{ 'products.card.sold_out' | t }}
    {%- endif -%}
  </button>
</div>
<div class="pdp__sticky-spacer" aria-hidden="true"></div>

{% render 'favorites-toggle' %}

{% stylesheet %}
  /* ---- Breadcrumb bar ---- */
  .pdp-breadcrumb {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    margin-block: var(--space-sm) var(--space-md);
    font-size: var(--font-size-sm);
    color: var(--color-muted);
  }

  .pdp-breadcrumb__trail {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2xs) var(--space-xs);
    min-width: 0;
  }

  .pdp-breadcrumb__trail a {
    color: var(--color-muted);
  }

  .pdp-breadcrumb__trail a:hover {
    color: var(--color-foreground);
  }

  .pdp-breadcrumb__trail [aria-current='page'] {
    color: var(--color-foreground);
  }

  .pdp-breadcrumb__back {
    flex-shrink: 0;
    color: var(--color-muted);
    font-size: var(--font-size-xs);
  }

  .pdp-breadcrumb__back:hover {
    color: var(--color-foreground);
  }

  @media (max-width: 749px) {
    .pdp-breadcrumb__back {
      display: none;
    }
  }

  .pdp {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
    margin-bottom: var(--space-xl);
  }

  @media (min-width: 750px) {
    .pdp {
      grid-template-columns: minmax(0, 45fr) minmax(0, 55fr);
      gap: var(--space-xl);
      align-items: start;
    }
  }

  /* ---- Gallery ---- */
  .pdp__media {
    position: relative;
    background-color: var(--color-surface);
  }

  .pdp__slide {
    display: none;
  }

  .pdp__slide.is-active {
    display: block;
  }

  .pdp__image {
    width: 100%;
    height: auto;
  }

  /* Discount badge over the gallery (top-left), like the source — mobile only */
  .pdp__discount-badge {
    display: none;
  }

  @media (max-width: 749px) {
    .pdp__discount-badge {
      position: absolute;
      top: var(--space-sm);
      left: var(--space-sm);
      z-index: 3;
      display: inline-flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-width: 5rem;
      padding: 0.6rem 0.9rem;
      border-radius: 0.8rem;
      background-color: var(--color-accent);
      color: var(--color-accent-contrast);
      line-height: 1.15;
      text-align: center;
    }

    .pdp__discount-badge strong {
      font-size: var(--font-size-md);
      font-weight: var(--font-weight-bold);
    }

    .pdp__discount-badge span {
      font-size: 1rem;
      text-transform: uppercase;
      letter-spacing: 0.02em;
    }
  }

  .pdp__code {
    position: absolute;
    top: 38%;
    right: var(--space-xs);
    z-index: 2;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 6.4rem;
    height: 6.4rem;
    border-radius: 50%;
    background-color: color-mix(in srgb, var(--color-muted) 82%, transparent);
    color: var(--color-accent-contrast);
    font-size: var(--font-size-xs);
    line-height: 1.25;
    text-align: center;
  }

  @media (max-width: 749px) {
    .pdp__media {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
    }

    .pdp__media::-webkit-scrollbar {
      display: none;
    }

    .pdp__slide {
      display: block;
      flex: 0 0 100%;
      scroll-snap-align: start;
    }

    .pdp__thumbs {
      display: none;
    }
  }

  .pdp__thumbs {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: var(--space-sm);
    margin-top: var(--space-md);
  }

  .pdp__thumb {
    padding: 0;
    border: 1px solid transparent;
    background-color: var(--color-surface);
    cursor: pointer;
  }

  .pdp__thumb.is-active {
    border-color: var(--color-muted);
  }

  .pdp__thumb img {
    display: block;
    width: 100%;
    height: auto;
  }

  /* ---- Info column ---- */
  .pdp__info {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .pdp__card {
    padding: var(--space-lg);
    background-color: var(--color-surface);
  }

  .pdp__title {
    margin-bottom: var(--space-xs);
    font-size: var(--font-size-md);
    font-weight: var(--font-weight-medium);
  }

  .pdp__sku {
    margin-bottom: var(--space-md);
    font-size: var(--font-size-xs);
    color: var(--color-muted);
  }

  /* ---- Price block ---- */
  .pdp__price {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-2xs);
  }

  /* Struck price lines up with the sale amount (badge width + row gap). */
  .pdp__price-compare {
    padding-left: 6.8rem;
    font-size: var(--font-size-md);
    color: var(--color-muted);
  }

  .pdp__price-row {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .pdp__price-badge {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-width: 5.6rem;
    min-height: 5.6rem;
    padding: var(--space-2xs) var(--space-xs);
    border-radius: 1rem;
    background-color: var(--color-accent);
    color: var(--color-accent-contrast);
    line-height: 1.2;
  }

  .pdp__price-badge > strong {
    font-size: var(--font-size-md);
    font-weight: var(--font-weight-medium);
  }

  .pdp__price-badge > span {
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .pdp__price-current {
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-bold);
  }

  .pdp__price--on-sale .pdp__price-current {
    color: var(--color-accent);
  }

  /* Mobile: discount % is shown on the image badge, so drop the inline
     price badge and remove the compare-price indent it reserved. */
  @media (max-width: 749px) {
    .pdp__price-badge {
      display: none;
    }

    .pdp__price-compare {
      padding-left: 0;
    }
  }

  .pdp__installments {
    margin-top: var(--space-xs);
    font-size: var(--font-size-xs);
    color: var(--color-muted);
  }

  .pdp__installments strong {
    display: block;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-normal);
    color: var(--color-muted);
  }

  .pdp__extra {
    display: inline-flex;
    align-items: baseline;
    gap: var(--space-sm);
    margin-top: var(--space-sm);
    padding: 0.6rem var(--space-md);
    border-radius: 0.6rem;
    background-color: var(--color-accent);
    color: var(--color-accent-contrast);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
  }

  .pdp__extra strong {
    font-size: var(--font-size-md);
    font-weight: var(--font-weight-bold);
  }

  /* ---- Side links (payment options, size chart) ---- */
  .pdp__side-link {
    align-self: flex-end;
    font-size: var(--font-size-xs);
    color: var(--color-foreground);
    text-decoration: underline;
    text-underline-offset: 0.3em;
  }

  .pdp__side-link--divided {
    width: 100%;
    padding-top: var(--space-md);
    border-top: 1px solid var(--color-border);
    text-align: right;
  }

  .pdp__label {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-sm);
    margin-bottom: var(--space-xs);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
  }

  /* ---- Colors ---- */
  .pdp__colors {
    padding-bottom: var(--space-md);
    border-bottom: 1px solid var(--color-border);
  }

  .pdp__color-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .pdp__color {
    display: block;
    width: 6rem;
    border: 1px solid var(--color-border);
    background-color: var(--color-surface);
  }

  .pdp__color.is-current {
    border-color: var(--color-accent);
  }

  .pdp__color img {
    display: block;
    width: 100%;
    height: auto;
  }

  /* ---- Sizes ---- */
  .pdp__sizes {
    margin: 0;
    padding: 0;
    border: 0;
  }

  .pdp__sizes legend {
    width: 100%;
    padding: 0;
  }

  .pdp__size-grid {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .pdp__size {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 4.4rem;
    height: 4.4rem;
    padding: 0 var(--space-xs);
    border: 1px solid var(--color-border);
    background-color: var(--color-background);
    font-size: var(--font-size-sm);
    cursor: pointer;
    transition: border-color var(--transition-base);
  }

  .pdp__size input {
    position: absolute;
    inset: 0;
    margin: 0;
    opacity: 0;
    cursor: inherit;
  }

  .pdp__size:has(input:checked) {
    border-color: var(--color-accent);
    border-width: 2px;
    font-weight: var(--font-weight-bold);
  }

  .pdp__size:has(input:focus-visible) {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .pdp__size--disabled {
    color: var(--color-muted);
    cursor: not-allowed;
  }

  .pdp__size--disabled::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top right,
      transparent calc(50% - 0.5px),
      var(--color-muted),
      transparent calc(50% + 0.5px)
    );
  }

  .pdp__variant-select {
    width: 100%;
    padding: var(--space-sm);
    border: 1px solid var(--color-border);
    font-size: var(--font-size-sm);
  }

  /* ---- Buy row ---- */
  .pdp__buy {
    display: flex;
    gap: var(--space-sm);
    margin-top: var(--space-md);
  }

  .pdp__qty {
    display: inline-flex;
    align-items: stretch;
    border: 1px solid var(--color-border);
    background-color: var(--color-background);
  }

  .pdp__qty button {
    width: 4rem;
    border: 0;
    background: transparent;
    font-size: var(--font-size-md);
    cursor: pointer;
  }

  .pdp__qty input {
    width: 4.8rem;
    border: 0;
    text-align: center;
    font-size: var(--font-size-sm);
    -moz-appearance: textfield;
    appearance: textfield;
  }

  .pdp__qty input::-webkit-outer-spin-button,
  .pdp__qty input::-webkit-inner-spin-button {
    appearance: none;
    margin: 0;
  }

  .pdp__submit {
    flex: 1;
    letter-spacing: 0.06em;
  }

  .pdp__favorite {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    align-self: flex-start;
    padding: 0;
    border: 0;
    background: transparent;
    color: var(--color-foreground);
    font-size: var(--font-size-sm);
    cursor: pointer;
  }

  .pdp__favorite svg {
    color: var(--color-accent);
  }

  .pdp__favorite.is-active svg {
    fill: var(--color-accent);
  }

  /* ---- Details box (accordions) ---- */
  .pdp__details {
    margin-top: var(--space-xs);
    padding: 0 var(--space-md);
    border: 1px solid var(--color-border);
  }

  .pdp__accordion + .pdp__accordion {
    border-top: 1px solid var(--color-border);
  }

  .pdp__accordion summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: var(--space-sm);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    cursor: pointer;
    list-style: none;
  }

  .pdp__accordion summary::-webkit-details-marker {
    display: none;
  }

  .pdp__accordion summary::after {
    content: '+';
    font-size: var(--font-size-md);
    color: var(--color-muted);
  }

  .pdp__accordion[open] summary::after {
    content: '−';
  }

  .pdp__accordion-content {
    padding-bottom: var(--space-md);
    font-size: var(--font-size-sm);
    color: var(--color-foreground);
  }

  /* Scrollable "Ürün Özellikleri" panel — matches source (fixed height + scrollbar) */
  .pdp__accordion-content--scroll {
    max-height: 22rem;
    overflow-y: auto;
    padding-right: var(--space-sm);
    scrollbar-width: thin;
    scrollbar-color: var(--color-foreground) var(--color-surface);
  }

  .pdp__accordion-content--scroll::-webkit-scrollbar {
    width: 8px;
  }

  .pdp__accordion-content--scroll::-webkit-scrollbar-track {
    background: var(--color-surface);
  }

  .pdp__accordion-content--scroll::-webkit-scrollbar-thumb {
    background: var(--color-foreground);
  }

  /* Description bullets (materials, sole, origin…) */
  .pdp__accordion-content ul {
    margin: 0 0 var(--space-sm);
    padding-left: 1.2em;
    color: var(--color-muted);
  }

  .pdp__accordion-content li {
    margin-bottom: 0.25em;
  }

  .pdp__accordion-content p {
    margin-bottom: var(--space-sm);
  }

  /* Striped spec table (Renk / Materyal / Topuk Boyu / Topuk Tipi) */
  .pdp__accordion-content table {
    width: 100%;
    border-collapse: collapse;
    margin-top: var(--space-sm);
  }

  .pdp__accordion-content td {
    padding: 0.7rem 1rem;
    font-size: var(--font-size-sm);
    vertical-align: top;
  }

  .pdp__accordion-content tr:nth-child(odd) td {
    background: var(--color-surface);
  }

  .pdp__accordion-content td:first-child {
    width: 40%;
    font-weight: var(--font-weight-medium);
    color: var(--color-foreground);
  }

  .pdp__empty-note {
    margin: 0;
    color: var(--color-muted);
  }

  /* Suggestions row */
  .pdp__suggests {
    display: flex;
    gap: var(--space-sm);
    overflow-x: auto;
    padding-bottom: var(--space-2xs);
    scrollbar-width: thin;
  }

  .pdp__suggest {
    flex: 0 0 9.5rem;
    color: var(--color-foreground);
  }

  .pdp__suggest-media {
    display: block;
    background: var(--color-surface);
  }

  .pdp__suggest-media img {
    display: block;
    width: 100%;
    height: auto;
  }

  .pdp__suggest-title {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-top: var(--space-2xs);
    font-size: var(--font-size-xs);
    line-height: 1.3;
  }

  .pdp__suggest-price {
    display: block;
    margin-top: var(--space-3xs, 2px);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    color: var(--color-accent);
  }

  /* Sticky add-to-cart bar (mobile only), like the source site */
  .pdp__sticky,
  .pdp__sticky-spacer {
    display: none;
  }

  @media (max-width: 749px) {
    .pdp__sticky {
      position: fixed;
      inset-inline: 0;
      bottom: 0;
      z-index: 40;
      display: flex;
      align-items: center;
      gap: var(--space-md);
      padding: var(--space-sm) var(--space-md);
      background-color: var(--color-background);
      border-top: 1px solid var(--color-border);
      box-shadow: 0 -4px 14px rgb(0 0 0 / 10%);
    }

    .pdp__sticky-price {
      display: flex;
      flex-direction: column;
      line-height: 1.15;
    }

    .pdp__sticky-price s {
      font-size: var(--font-size-xs);
      color: var(--color-muted);
    }

    .pdp__sticky-current {
      font-size: var(--font-size-md);
      font-weight: var(--font-weight-bold);
    }

    .pdp__sticky-price--on-sale .pdp__sticky-current {
      color: var(--color-accent);
    }

    .pdp__sticky-add {
      flex: 1;
      letter-spacing: 0.04em;
    }

    /* Reserve space so the fixed bar never hides page content/footer. */
    .pdp__sticky-spacer {
      display: block;
      height: 6.4rem;
    }
  }
{% endstylesheet %}

{% javascript %}
  (() => {
    document.querySelectorAll('[data-gallery-thumb]').forEach((thumb) => {
      thumb.addEventListener('click', () => {
        const index = thumb.dataset.galleryThumb;

        document.querySelectorAll('[data-gallery-slide]').forEach((slide) => {
          slide.classList.toggle('is-active', slide.dataset.gallerySlide === index);
        });

        document.querySelectorAll('[data-gallery-thumb]').forEach((t) => {
          t.classList.toggle('is-active', t === thumb);
        });
      });
    });

    document.querySelectorAll('[data-qty-change]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const input = btn.closest('.pdp__qty').querySelector('[data-qty-input]');
        const next = (parseInt(input.value, 10) || 1) + parseInt(btn.dataset.qtyChange, 10);
        input.value = Math.max(1, next);
      });
    });

    document.querySelectorAll('[data-back-link]').forEach((link) => {
      link.addEventListener('click', (event) => {
        if (window.history.length > 1) {
          event.preventDefault();
          window.history.back();
        }
      });
    });
  })();
{% endjavascript %}

