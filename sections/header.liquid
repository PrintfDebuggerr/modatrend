{% comment %}
  Modatrend header.

  Desktop: three stacked rows — utility bar (gray), main bar
  (logo / search / account / cart), category nav with hover dropdowns.
  Desktop header is not sticky, matching the source site.

  Mobile (<750px): single compact sticky bar — hamburger + search on the
  left, centered logo, account + cart on the right. The hamburger opens a
  left slide-in drawer built on <details scroll-lock> with nested
  <details> for subcategories.
{% endcomment %}

{%- liquid
  assign menu = section.settings.menu
  assign utility_menu = section.settings.utility_menu
  assign whatsapp_number = section.settings.whatsapp_number
-%}

<header class="header full-width">
  <div class="header__utility">
    <div class="container header__utility-inner">
      {%- if utility_menu.links.size > 0 -%}
        <ul class="header__utility-menu" role="list">
          {%- for link in utility_menu.links -%}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {%- endfor -%}
        </ul>
      {%- endif -%}

      <div class="header__utility-right">
        {%- if whatsapp_number != blank -%}
          <a
            class="header__whatsapp"
            href="https://api.whatsapp.com/send?phone={{ whatsapp_number }}"
            target="_blank"
            rel="noopener"
          >
            <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor" aria-hidden="true" focusable="false">
              <path d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5-1.3A10 10 0 1 0 12 2zm5.3 14.1c-.2.6-1.2 1.2-1.7 1.2-.4.1-1 .1-1.6-.1a14 14 0 0 1-1.5-.5 11.5 11.5 0 0 1-4.4-3.9 5 5 0 0 1-1-2.7c0-1.3.7-1.9 1-2.2a1 1 0 0 1 .7-.3h.5c.2 0 .4 0 .6.4l.9 2.1c0 .2.1.3 0 .5l-.3.5-.5.5c-.1.2-.3.3-.1.6a8.7 8.7 0 0 0 1.6 2 8 8 0 0 0 2.3 1.4c.3.2.5.1.6 0l.7-.8c.2-.3.4-.2.6-.1l1.9.9c.2.1.4.2.4.3 0 .2 0 .7-.2 1.2z"></path>
            </svg>
            {{ 'sections.header.whatsapp_line' | t: phone: section.settings.whatsapp_display }}
          </a>
        {%- endif -%}

        {%- if section.settings.favorites_url != blank -%}
          <a class="header__favorites" href="{{ section.settings.favorites_url }}">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
              <path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.6l-1-1a5.5 5.5 0 0 0-7.8 7.8l1 1L12 21.2l7.8-7.8 1-1a5.5 5.5 0 0 0 0-7.8z"></path>
            </svg>
            {{ 'sections.header.favorites' | t }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>

  <div class="container header__main">
    <div class="header__main-left">
      <details class="header__drawer" scroll-lock data-header-drawer>
        <summary class="header__burger" aria-label="{{ 'sections.header.open_menu' | t }}">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true" focusable="false">
            <path d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
          <span class="header__burger-label">{{ 'sections.header.menu' | t }}</span>
        </summary>

        <div class="header__drawer-panel">
          <nav aria-label="{{ 'sections.header.menu' | t }}">
            <ul class="header__drawer-list" role="list">
              {%- for link in menu.links -%}
                <li>
                  {%- if link.links.size > 0 -%}
                    <details class="header__drawer-sub">
                      <summary>
                        <span>{{ link.title }}</span>
                        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                          <path d="M6 5l6 7-6 7M13 5l6 7-6 7"></path>
                        </svg>
                      </summary>
                      <ul role="list">
                        <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                        {%- for child in link.links -%}
                          <li><a href="{{ child.url }}">{{ child.title }}</a></li>
                        {%- endfor -%}
                      </ul>
                    </details>
                  {%- else -%}
                    <a href="{{ link.url }}"{% if link.current %} aria-current="page"{% endif %}>{{ link.title }}</a>
                  {%- endif -%}
                </li>
              {%- endfor -%}
            </ul>
          </nav>
        </div>
      </details>

      <a class="header__search-link" href="{{ routes.search_url }}" aria-label="{{ 'search.title' | t }}">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true" focusable="false">
          <circle cx="11" cy="11" r="7"></circle>
          <path d="m20 20-3.8-3.8"></path>
        </svg>
      </a>
    </div>

    <a class="header__logo" href="{{ routes.root_url }}">
      {%- if section.settings.logo -%}
        {{
          section.settings.logo
          | image_url: width: 460
          | image_tag: widths: '230, 460', class: 'header__logo-image', alt: shop.name
        }}
      {%- else -%}
        {%- assign accent = section.settings.logo_accent -%}
        {%- if accent != blank and shop.name contains accent -%}
          {%- assign logo_parts = shop.name | split: accent -%}
          <span class="header__logo-text">{{- logo_parts[0] -}}<em>{{- accent -}}</em>{{- logo_parts[1] -}}</span>
        {%- else -%}
          <span class="header__logo-text">{{ shop.name }}</span>
        {%- endif -%}
      {%- endif -%}
    </a>

    <form class="header__search" action="{{ routes.search_url }}" method="get" role="search">
      <input
        type="search"
        name="q"
        value="{{ search.terms | escape }}"
        placeholder="{{ 'search.placeholder' | t }}"
        aria-label="{{ 'search.title' | t }}"
      >
      <button type="submit" aria-label="{{ 'search.submit' | t }}">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true" focusable="false">
          <circle cx="11" cy="11" r="7"></circle>
          <path d="m20 20-3.8-3.8"></path>
        </svg>
      </button>
    </form>

    <div class="header__icons">
      {%- if shop.customer_accounts_enabled -%}
        <shopify-account menu="{{ section.settings.customer_account_menu }}">
          {{ 'icon-account.svg' | inline_asset_content }}
        </shopify-account>
      {%- endif -%}

      <a class="header__cart" href="{{ routes.cart_url }}" aria-label="{{ 'cart.title' | t }}">
        {{ 'icon-cart.svg' | inline_asset_content }}
        {%- if cart.item_count > 0 -%}
          <span class="header__cart-count" aria-hidden="true">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>
    </div>
  </div>

  <nav class="header__nav container" aria-label="{{ 'sections.header.menu' | t }}">
    <ul class="header__nav-list" role="list">
      {%- for link in menu.links -%}
        <li class="header__nav-item">
          <a
            class="header__nav-link"
            href="{{ link.url }}"
            {% if link.current %}aria-current="page"{% endif %}
          >
            {{ link.title }}
          </a>
          {%- if link.links.size > 0 -%}
            <ul class="header__submenu" role="list">
              {%- for child in link.links -%}
                <li>
                  <a href="{{ child.url }}"{% if child.current %} aria-current="page"{% endif %}>{{ child.title }}</a>
                </li>
              {%- endfor -%}
            </ul>
          {%- endif -%}
        </li>
      {%- endfor -%}
    </ul>
  </nav>
</header>

{% stylesheet %}
  .header {
    background-color: var(--color-background);
    border-bottom: 1px solid var(--color-border);
  }

  /* ---- Utility bar ---- */
  .header__utility {
    background-color: var(--color-surface);
    font-size: var(--font-size-xs);
  }

  .header__utility-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 3.6rem;
    gap: var(--space-md);
  }

  .header__utility-menu {
    display: flex;
    gap: var(--space-md);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .header__utility-right {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
  }

  .header__whatsapp,
  .header__favorites {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2xs);
  }

  .header__favorites {
    text-transform: uppercase;
  }

  /* ---- Main bar ---- */
  .header__main {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: var(--space-md);
    min-height: 5.2rem;
  }

  .header__main-left {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .header__logo {
    justify-self: center;
    display: inline-flex;
    align-items: center;
  }

  .header__logo-image {
    max-height: 4rem;
    width: auto;
  }

  .header__logo-text {
    font-size: 2.8rem;
    font-weight: var(--font-weight-bold);
    text-transform: lowercase;
    letter-spacing: -0.02em;
    color: var(--color-foreground);
  }

  .header__logo-text em {
    font-style: normal;
    color: var(--color-accent);
  }

  .header__logo:hover .header__logo-text {
    color: var(--color-foreground);
  }

  .header__search {
    display: none;
  }

  .header__icons {
    justify-self: end;
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .header__icons svg {
    width: 2.2rem;
    height: auto;
  }

  .header__cart {
    position: relative;
    display: inline-flex;
  }

  .header__cart-count {
    position: absolute;
    top: -0.6rem;
    right: -0.8rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.8rem;
    height: 1.8rem;
    padding: 0 0.4rem;
    border-radius: 50%;
    background-color: var(--color-accent);
    color: var(--color-accent-contrast);
    font-size: 1.1rem;
    font-weight: var(--font-weight-bold);
    line-height: 1;
  }

  /* ---- Mobile drawer ---- */
  .header__drawer > summary {
    list-style: none;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
    cursor: pointer;
  }

  .header__drawer > summary::-webkit-details-marker {
    display: none;
  }

  .header__burger-label {
    font-size: 1rem;
    line-height: 1;
  }

  .header__drawer[open]::before {
    content: '';
    position: fixed;
    inset: 0;
    z-index: 40;
    background-color: rgb(0 0 0 / 45%);
  }

  .header__drawer-panel {
    position: fixed;
    inset-block: 0;
    left: 0;
    z-index: 50;
    width: min(32rem, 85vw);
    overflow-y: auto;
    padding: var(--space-lg) var(--space-md);
    background-color: var(--color-background);
    transition: translate 0.25s ease;
  }

  @starting-style {
    .header__drawer[open] .header__drawer-panel {
      translate: -100% 0;
    }
  }

  .header__drawer-list {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .header__drawer-list > li {
    border-bottom: 1px solid var(--color-border);
  }

  .header__drawer-list > li > a,
  .header__drawer-sub > summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-sm) 0;
    font-size: var(--font-size-sm);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    cursor: pointer;
  }

  .header__drawer-sub > summary {
    list-style: none;
  }

  .header__drawer-sub > summary::-webkit-details-marker {
    display: none;
  }

  .header__drawer-list a[aria-current='page'] {
    color: var(--color-accent);
    font-weight: var(--font-weight-bold);
  }

  .header__drawer-sub > ul {
    margin: 0;
    padding: 0 0 var(--space-sm) var(--space-md);
    list-style: none;
  }

  .header__drawer-sub > ul a {
    display: block;
    padding: var(--space-xs) 0;
    font-size: var(--font-size-sm);
  }

  /* ---- Desktop nav ---- */
  .header__nav {
    display: none;
  }

  .header__nav-list {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .header__nav-item {
    position: relative;
  }

  .header__nav-link {
    display: inline-flex;
    align-items: center;
    padding: var(--space-sm) var(--space-md);
    font-size: var(--font-size-base);
  }

  .header__nav-link[aria-current='page'] {
    color: var(--color-accent);
    font-weight: var(--font-weight-bold);
  }

  .header__submenu {
    position: absolute;
    top: 100%;
    left: 0;
    z-index: 30;
    display: none;
    min-width: 22rem;
    margin: 0;
    padding: var(--space-sm) 0;
    list-style: none;
    background-color: var(--color-background);
    border: 1px solid var(--color-border);
  }

  .header__nav-item:is(:hover, :focus-within) .header__submenu {
    display: block;
  }

  .header__submenu a {
    display: block;
    padding: var(--space-xs) var(--space-md);
    font-size: var(--font-size-sm);
  }

  .header__submenu a:hover {
    background-color: var(--color-surface);
  }

  /* ---- Responsive ---- */
  @media (max-width: 749px) {
    .header__utility {
      display: none;
    }
  }

  @media (min-width: 750px) {
    .header__drawer,
    .header__search-link {
      display: none;
    }

    .header__main {
      grid-template-columns: auto 1fr auto;
      min-height: 7.2rem;
    }

    .header__logo {
      justify-self: start;
      order: -1;
    }

    .header__search {
      display: flex;
      width: 100%;
      max-width: 46rem;
      margin-inline: auto;
      background-color: var(--color-surface);
    }

    .header__search input {
      flex: 1;
      min-width: 0;
      padding: var(--space-sm) var(--space-md);
      border: 0;
      background: transparent;
      font-size: var(--font-size-sm);
    }

    .header__search input:focus-visible {
      outline: 2px solid var(--color-accent);
      outline-offset: -2px;
    }

    .header__search button {
      display: inline-flex;
      align-items: center;
      padding: 0 var(--space-md);
      border: 0;
      background: transparent;
      color: var(--color-accent);
      cursor: pointer;
    }

    .header__nav {
      display: block;
      border-top: 1px solid var(--color-border);
    }
  }

  /* Sticky compact header on mobile only (desktop scrolls away, like the source site) */
  @media (max-width: 749px) {
    .shopify-section:has(> .header) {
      position: sticky;
      top: 0;
      z-index: 30;
    }
  }
{% endstylesheet %}

{% javascript %}
  (() => {
    const drawer = document.querySelector('[data-header-drawer]');
    if (!drawer) return;

    const close = () => drawer.removeAttribute('open');

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && drawer.hasAttribute('open')) close();
    });

    drawer.addEventListener('click', (event) => {
      if (event.target === drawer) close();
      if (event.target.closest('a')) close();
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "t:labels.logo"
    },
    {
      "type": "text",
      "id": "logo_accent",
      "label": "t:labels.logo_accent",
      "info": "t:info.logo_accent",
      "default": "trend"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu",
      "default": "main-menu"
    },
    {
      "type": "link_list",
      "id": "utility_menu",
      "label": "t:labels.utility_menu"
    },
    {
      "type": "link_list",
      "id": "customer_account_menu",
      "label": "t:labels.customer_account_menu",
      "default": "customer-account-main-menu"
    },
    {
      "type": "text",
      "id": "whatsapp_number",
      "label": "t:labels.whatsapp_number",
      "info": "t:info.whatsapp_number"
    },
    {
      "type": "text",
      "id": "whatsapp_display",
      "label": "t:labels.whatsapp_display"
    },
    {
      "type": "url",
      "id": "favorites_url",
      "label": "t:labels.favorites_url"
    }
  ]
}
{% endschema %}
