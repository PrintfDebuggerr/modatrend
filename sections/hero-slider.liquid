{% comment %}
  Home hero slider, styled after the source site: full-width slides with
  a soft pastel gradient, an editorial serif headline, and an underlined
  "ALIŞVERİŞE BAŞLA" style CTA. Scroll-snap track with arrows and dots;
  optional autoplay.

  Each slide is a block. Image priority: uploaded image, then external
  image URL (used to mirror the source's Ticimax 1920x800 banners during
  development). If neither is set the slide renders the pastel gradient
  background so the section looks right before assets exist.
{% endcomment %}

<div class="hero full-width" data-hero{% if section.settings.autoplay %} data-hero-autoplay{% endif %}>
  <div class="hero__track" data-hero-track>
    {%- for block in section.blocks -%}
      <div class="hero__slide" data-hero-slide {{ block.shopify_attributes }}>
        {%- liquid
          assign slide_loading = 'lazy'
          if forloop.first
            assign slide_loading = 'eager'
          endif
        -%}
        {%- if block.settings.image -%}
          {{
            block.settings.image
            | image_url: width: 2400
            | image_tag:
              widths: '800, 1200, 1600, 2400',
              sizes: '100vw',
              class: 'hero__image',
              loading: slide_loading,
              alt: block.settings.alt
          }}
        {%- elsif block.settings.image_url != blank -%}
          <img
            class="hero__image"
            src="{{ block.settings.image_url }}"
            alt="{{ block.settings.alt | escape }}"
            width="1920"
            height="800"
            loading="{{ slide_loading }}"
            {% if forloop.first %}fetchpriority="high"{% endif %}
          >
        {%- endif -%}

        <div class="hero__content container">
          {%- if block.settings.eyebrow != blank -%}
            <p class="hero__eyebrow">{{ block.settings.eyebrow }}</p>
          {%- endif -%}
          {%- if block.settings.heading != blank -%}
            <h2 class="hero__heading">{{ block.settings.heading }}</h2>
          {%- endif -%}
          {%- if block.settings.link != blank and block.settings.cta_label != blank -%}
            <a class="hero__cta" href="{{ block.settings.link }}">{{ block.settings.cta_label }}</a>
          {%- endif -%}
        </div>

        {%- if block.settings.link != blank and block.settings.cta_label == blank -%}
          <a class="hero__slide-link" href="{{ block.settings.link }}" aria-label="{{ block.settings.heading | default: block.settings.eyebrow | default: block.settings.alt | escape }}"></a>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>

  {%- if section.blocks.size > 1 -%}
    <button type="button" class="hero__arrow hero__arrow--prev" data-hero-prev aria-label="{{ 'sections.hero.previous' | t }}">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="m15 5-7 7 7 7"></path></svg>
    </button>
    <button type="button" class="hero__arrow hero__arrow--next" data-hero-next aria-label="{{ 'sections.hero.next' | t }}">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="m9 5 7 7-7 7"></path></svg>
    </button>

    <div class="hero__dots" data-hero-dots>
      {%- for block in section.blocks -%}
        <button
          type="button"
          data-hero-dot="{{ forloop.index0 }}"
          {% if forloop.first %}class="is-active"{% endif %}
          aria-label="{{ 'sections.hero.go_to_slide' | t: index: forloop.index }}"
        ></button>
      {%- endfor -%}
    </div>
  {%- endif -%}
</div>

{% stylesheet %}
  .hero {
    position: relative;
  }

  .hero__track {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
  }

  .hero__track::-webkit-scrollbar {
    display: none;
  }

  .hero__slide {
    position: relative;
    display: flex;
    align-items: center;
    flex: 0 0 100%;
    scroll-snap-align: start;
    aspect-ratio: 12 / 5;
    overflow: hidden;
    background: linear-gradient(105deg, #fdf6d8 0%, #fbe3cf 45%, #f6cdb4 100%);
  }

  /* Taller, larger hero on mobile (matches source proportions) */
  @media (max-width: 749px) {
    .hero__slide {
      aspect-ratio: 4 / 5;
    }
  }

  .hero__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero__content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-sm);
  }

  .hero__eyebrow {
    font-family: Georgia, 'Times New Roman', serif;
    font-style: italic;
    font-size: var(--font-size-md);
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--color-foreground);
  }

  .hero__heading {
    font-family: Georgia, 'Times New Roman', serif;
    font-weight: var(--font-weight-normal);
    font-size: clamp(2.4rem, 6vw, 6.4rem);
    line-height: 1.05;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-foreground);
    max-width: 18ch;
  }

  .hero__cta {
    margin-top: var(--space-xs);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-bold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: underline;
    text-underline-offset: 0.5em;
    color: var(--color-foreground);
  }

  .hero__slide-link {
    position: absolute;
    inset: 0;
    z-index: 3;
  }

  .hero__arrow {
    position: absolute;
    top: 50%;
    z-index: 4;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 4.4rem;
    height: 4.4rem;
    border: 0;
    background-color: color-mix(in srgb, var(--color-background) 85%, transparent);
    color: var(--color-foreground);
    cursor: pointer;
    translate: 0 -50%;
    transition: background-color var(--transition-base);
  }

  .hero__arrow:hover {
    background-color: var(--color-background);
  }

  .hero__arrow--prev {
    left: var(--space-md);
  }

  .hero__arrow--next {
    right: var(--space-md);
  }

  @media (max-width: 749px) {
    .hero__arrow {
      display: none;
    }
  }

  .hero__dots {
    position: absolute;
    bottom: var(--space-sm);
    left: 50%;
    z-index: 4;
    display: flex;
    gap: var(--space-xs);
    translate: -50% 0;
  }

  .hero__dots button {
    width: 0.9rem;
    height: 0.9rem;
    padding: 0;
    border: 1px solid var(--color-foreground);
    border-radius: 50%;
    background: transparent;
    cursor: pointer;
  }

  .hero__dots button.is-active {
    background-color: var(--color-foreground);
  }
{% endstylesheet %}

{% javascript %}
  (() => {
    document.querySelectorAll('[data-hero]').forEach((hero) => {
      const track = hero.querySelector('[data-hero-track]');
      const slides = hero.querySelectorAll('[data-hero-slide]');
      const dots = hero.querySelectorAll('[data-hero-dot]');
      if (!track || slides.length < 2) return;

      const index = () => Math.round(track.scrollLeft / track.clientWidth);

      const goTo = (i) => {
        const target = Math.max(0, Math.min(slides.length - 1, i));
        track.scrollTo({ left: target * track.clientWidth, behavior: 'smooth' });
      };

      hero.querySelector('[data-hero-prev]')?.addEventListener('click', () => goTo(index() - 1));
      hero.querySelector('[data-hero-next]')?.addEventListener('click', () => goTo(index() + 1));

      dots.forEach((dot) => {
        dot.addEventListener('click', () => goTo(parseInt(dot.dataset.heroDot, 10)));
      });

      track.addEventListener('scroll', () => {
        const i = index();
        dots.forEach((dot, d) => dot.classList.toggle('is-active', d === i));
      }, { passive: true });

      if (hero.hasAttribute('data-hero-autoplay')) {
        let timer = setInterval(() => goTo((index() + 1) % slides.length), 5500);
        hero.addEventListener('pointerenter', () => clearInterval(timer));
        hero.addEventListener('pointerleave', () => {
          timer = setInterval(() => goTo((index() + 1) % slides.length), 5500);
        });
      }
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:general.hero",
  "settings": [
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "t:labels.autoplay",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "t:general.slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:labels.image"
        },
        {
          "type": "text",
          "id": "image_url",
          "label": "t:labels.image_url",
          "info": "t:info.image_url"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "t:labels.alt"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "t:labels.eyebrow"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "t:labels.heading"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:labels.link"
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "t:labels.cta_label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:general.hero",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
