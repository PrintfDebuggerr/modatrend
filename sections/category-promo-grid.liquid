{% comment %}
  Category promo grid, matching the source site's tiles: rounded-corner
  banner images (gradient background and label are baked into the
  artwork) in a 2- or 3-column layout; single column on mobile.

  Each tile is a block. Image priority: uploaded image > external image
  URL (used to mirror the source's Ticimax banners during development)
  > collection image > first product image. The overlay label renders
  only when set — the source banners carry their own label.
{% endcomment %}

<div class="promo-grid promo-grid--cols-{{ section.settings.columns }}">
  {%- for block in section.blocks -%}
    {%- liquid
      assign tile_collection = block.settings.collection
      assign tile_image = block.settings.image | default: tile_collection.featured_image
      assign tile_label = block.settings.label
      assign tile_url = block.settings.link | default: tile_collection.url | default: routes.all_products_collection_url
      assign tile_alt = tile_label | default: tile_collection.title
    -%}
    <a class="promo-tile" href="{{ tile_url }}" {{ block.shopify_attributes }}>
      {%- if block.settings.image -%}
        {{
          block.settings.image
          | image_url: width: 1200
          | image_tag:
            widths: '600, 900, 1200',
            sizes: '(min-width: 750px) 50vw, 100vw',
            class: 'promo-tile__image',
            loading: 'lazy',
            alt: tile_alt
        }}
      {%- elsif block.settings.image_url != blank -%}
        <img class="promo-tile__image" src="{{ block.settings.image_url }}" loading="lazy" alt="{{ tile_alt | escape }}" width="800" height="800">
      {%- elsif tile_image -%}
        {{
          tile_image
          | image_url: width: 1200
          | image_tag:
            widths: '600, 900, 1200',
            sizes: '(min-width: 750px) 50vw, 100vw',
            class: 'promo-tile__image',
            loading: 'lazy',
            alt: tile_alt
        }}
      {%- endif -%}
      {%- if tile_label != blank -%}
        <span class="promo-tile__label">{{ tile_label }}</span>
      {%- endif -%}
    </a>
  {%- endfor -%}
</div>

{% stylesheet %}
  .promo-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-sm);
    margin-block: var(--space-sm);
  }

  @media (min-width: 750px) {
    .promo-grid {
      gap: var(--space-lg);
      margin-block: var(--space-lg) 0;
    }

    .promo-grid--cols-2 {
      grid-template-columns: repeat(2, 1fr);
    }

    .promo-grid--cols-3 {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .promo-tile {
    position: relative;
    display: block;
    overflow: hidden;
    border-radius: 1.2rem;
    background: linear-gradient(160deg, #fdf3e3 0%, #fbe0cd 60%, #f7cdb6 100%);
  }

  .promo-tile__image {
    display: block;
    width: 100%;
    height: auto;
    transition: transform var(--transition-base);
  }

  .promo-tile:hover .promo-tile__image {
    transform: scale(1.02);
  }

  .promo-tile__label {
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    z-index: 2;
    padding: var(--space-sm);
    color: var(--color-foreground);
    font-size: var(--font-size-lg);
    text-align: center;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.category_grid",
  "settings": [
    {
      "type": "select",
      "id": "columns",
      "label": "t:labels.columns",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" }
      ],
      "default": "3"
    }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "t:general.tile",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "t:labels.collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:labels.image"
        },
        {
          "type": "text",
          "id": "image_url",
          "label": "t:labels.image_url",
          "info": "t:info.image_url"
        },
        {
          "type": "text",
          "id": "label",
          "label": "t:labels.text"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:labels.link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:general.category_grid",
      "blocks": [
        { "type": "tile" },
        { "type": "tile" },
        { "type": "tile" }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
