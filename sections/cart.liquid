{% comment %}
  Cart page, styled after the source site's checkout cart:
  line items (image, title, variant/SKU, qty stepper, line price) on the
  left; a "Sipariş Özeti" summary card (subtotal, discounts, total,
  checkout CTA) on the right. Single column on mobile with a sticky
  bottom total + CTA bar.
{% endcomment %}

<div class="cart-page">
  <div class="cart-page__header">
    <h1 class="cart-page__title">
      {{ 'cart.title' | t }}
      {%- if cart.item_count > 0 %} ({{ cart.item_count }}){% endif -%}
    </h1>
    {%- if cart.item_count > 0 -%}
      <a class="cart-page__clear" href="{{ routes.cart_clear_url }}">{{ 'cart.clear' | t }}</a>
    {%- endif -%}
  </div>

  {%- if cart.item_count == 0 -%}
    <div class="cart-page__empty">
      <p>{{ 'cart.empty' | t }}</p>
      <a class="button" href="{{ routes.all_products_collection_url }}">{{ 'cart.continue' | t }}</a>
    </div>
  {%- else -%}
    <form action="{{ routes.cart_url }}" method="post" class="cart-page__layout" data-cart-form>
      <ul class="cart-items" role="list">
        {%- for item in cart.items -%}
          <li class="cart-item">
            <a class="cart-item__media" href="{{ item.url }}">
              {%- if item.image -%}
                {{ item.image | image_url: width: 240 | image_tag: widths: '120, 240', class: 'cart-item__image', loading: 'lazy', alt: item.title }}
              {%- endif -%}
            </a>

            <div class="cart-item__details">
              <a class="cart-item__title" href="{{ item.url }}">{{ item.product.title }}</a>

              {%- unless item.product.has_only_default_variant -%}
                <p class="cart-item__meta">
                  {%- for option in item.options_with_values -%}
                    {{ option.name }}: {{ option.value }}{% unless forloop.last %} · {% endunless %}
                  {%- endfor -%}
                </p>
              {%- endunless -%}

              {%- if item.sku != blank -%}
                <p class="cart-item__meta">{{ item.sku }}</p>
              {%- endif -%}

              <div class="cart-item__qty">
                <button type="button" data-qty-change="-1" aria-label="{{ 'products.product.decrease_qty' | t }}">−</button>
                <input
                  type="number"
                  name="updates[]"
                  value="{{ item.quantity }}"
                  min="0"
                  inputmode="numeric"
                  aria-label="{{ 'products.product.quantity' | t }}"
                  data-qty-input
                >
                <button type="button" data-qty-change="1" aria-label="{{ 'products.product.increase_qty' | t }}">+</button>
              </div>

              <a class="cart-item__remove" href="{{ item.url_to_remove }}">{{ 'cart.remove' | t }}</a>
            </div>

            <div class="cart-item__price">
              {%- if item.original_line_price > item.final_line_price -%}
                <s class="cart-item__price-compare">{{ item.original_line_price | money }}</s>
              {%- endif -%}
              <span class="cart-item__price-final">{{ item.final_line_price | money }}</span>
            </div>
          </li>
        {%- endfor -%}
      </ul>

      <aside class="cart-summary">
        <h2 class="cart-summary__title">{{ 'cart.summary' | t }}</h2>

        <div class="cart-summary__row">
          <span>{{ 'cart.subtotal' | t }}</span>
          <span>{{ cart.items_subtotal_price | money }}</span>
        </div>

        {%- if cart.total_discount > 0 -%}
          <div class="cart-summary__row cart-summary__row--discount">
            <span>{{ 'cart.discounts' | t }}</span>
            <span>−{{ cart.total_discount | money }}</span>
          </div>
        {%- endif -%}

        <div class="cart-summary__row cart-summary__row--total">
          <span>{{ 'cart.total' | t }}</span>
          <span>{{ cart.total_price | money }}</span>
        </div>

        <button type="submit" name="checkout" class="button cart-summary__checkout">
          {{ 'cart.checkout' | t }}
        </button>

        <a class="cart-summary__continue" href="{{ routes.all_products_collection_url }}">
          {{ 'cart.continue' | t }}
        </a>
      </aside>

      <div class="cart-sticky">
        <div class="cart-sticky__total">
          <span>{{ 'cart.total' | t }}</span>
          <strong>{{ cart.total_price | money }}</strong>
        </div>
        <button type="submit" name="checkout" class="button cart-sticky__checkout">
          {{ 'cart.checkout' | t }}
        </button>
      </div>
    </form>
  {%- endif -%}
</div>

{% stylesheet %}
  .cart-page {
    margin-block: var(--space-lg) var(--space-2xl);
  }

  .cart-page__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .cart-page__title {
    font-size: var(--font-size-xl);
  }

  .cart-page__clear {
    font-size: var(--font-size-xs);
    color: var(--color-muted);
    text-decoration: underline;
  }

  .cart-page__empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-lg);
    padding-block: var(--space-2xl);
    text-align: center;
    color: var(--color-muted);
  }

  .cart-page__layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
    align-items: start;
  }

  @media (min-width: 990px) {
    .cart-page__layout {
      grid-template-columns: minmax(0, 8fr) minmax(0, 4fr);
      gap: var(--space-2xl);
    }
  }

  /* ---- Line items ---- */
  .cart-items {
    display: flex;
    flex-direction: column;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .cart-item {
    display: grid;
    grid-template-columns: 9.6rem 1fr auto;
    gap: var(--space-md);
    padding-block: var(--space-md);
    border-bottom: 1px solid var(--color-border);
  }

  .cart-item__media {
    display: block;
    background-color: var(--color-surface);
  }

  .cart-item__image {
    width: 100%;
    height: auto;
  }

  .cart-item__details {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
  }

  .cart-item__title {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
  }

  .cart-item__meta {
    font-size: var(--font-size-xs);
    color: var(--color-muted);
  }

  .cart-item__qty {
    display: inline-flex;
    align-items: stretch;
    align-self: flex-start;
    margin-top: var(--space-xs);
    border: 1px solid var(--color-border);
  }

  .cart-item__qty button {
    width: 3.2rem;
    border: 0;
    background: transparent;
    font-size: var(--font-size-md);
    cursor: pointer;
  }

  .cart-item__qty input {
    width: 4rem;
    border: 0;
    text-align: center;
    font-size: var(--font-size-sm);
    appearance: textfield;
  }

  .cart-item__qty input::-webkit-outer-spin-button,
  .cart-item__qty input::-webkit-inner-spin-button {
    appearance: none;
    margin: 0;
  }

  .cart-item__remove {
    align-self: flex-start;
    font-size: var(--font-size-xs);
    color: var(--color-muted);
    text-decoration: underline;
  }

  .cart-item__price {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: var(--space-2xs);
    text-align: right;
  }

  .cart-item__price-compare {
    font-size: var(--font-size-xs);
    color: var(--color-muted);
  }

  .cart-item__price-final {
    font-size: var(--font-size-md);
    font-weight: var(--font-weight-bold);
    color: var(--color-accent);
  }

  /* ---- Summary ---- */
  .cart-summary {
    padding: var(--space-lg);
    background-color: var(--color-surface);
  }

  .cart-summary__title {
    margin-bottom: var(--space-md);
    font-size: var(--font-size-md);
  }

  .cart-summary__row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: var(--space-xs);
    font-size: var(--font-size-sm);
    border-bottom: 1px solid var(--color-border);
  }

  .cart-summary__row--discount {
    color: var(--color-accent);
  }

  .cart-summary__row--total {
    border-bottom: 0;
    font-size: var(--font-size-md);
    font-weight: var(--font-weight-bold);
  }

  .cart-summary__checkout {
    width: 100%;
    margin-top: var(--space-md);
  }

  .cart-summary__continue {
    display: block;
    margin-top: var(--space-sm);
    font-size: var(--font-size-sm);
    text-align: center;
    text-decoration: underline;
  }

  /* ---- Mobile sticky bar ---- */
  .cart-sticky {
    display: none;
  }

  @media (max-width: 989px) {
    .cart-summary__checkout {
      display: none;
    }

    .cart-sticky {
      position: sticky;
      bottom: 0;
      z-index: 10;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-md);
      padding: var(--space-sm) var(--space-md);
      background-color: var(--color-background);
      border-top: 1px solid var(--color-border);
    }

    .cart-sticky__total {
      display: flex;
      flex-direction: column;
      font-size: var(--font-size-xs);
      color: var(--color-muted);
    }

    .cart-sticky__total strong {
      font-size: var(--font-size-md);
      color: var(--color-foreground);
    }

    .cart-sticky__checkout {
      flex: 1;
      max-width: 24rem;
    }
  }
{% endstylesheet %}

{% javascript %}
  (() => {
    const form = document.querySelector('[data-cart-form]');
    if (!form) return;

    form.addEventListener('click', (event) => {
      const btn = event.target.closest('[data-qty-change]');
      if (!btn) return;

      const input = btn.closest('.cart-item__qty').querySelector('[data-qty-input]');
      const next = (parseInt(input.value, 10) || 0) + parseInt(btn.dataset.qtyChange, 10);
      input.value = Math.max(0, next);
      form.submit();
    });

    form.addEventListener('change', (event) => {
      if (event.target.matches('[data-qty-input]')) form.submit();
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:general.cart",
  "settings": []
}
{% endschema %}
