{% comment %}
  Featured collection rail: centered uppercase heading, optional
  "view all" link, and a horizontal scroll-snap track of product cards
  (2-up on mobile, 4-up on desktop) — like the source site's featured
  product rows.
{% endcomment %}

{%- liquid
  assign featured = section.settings.collection
  assign heading = section.settings.heading | default: featured.title
  assign limit = section.settings.max_products
-%}

{%- if featured and featured.products_count > 0 -%}
  <div class="featured">
    <div class="featured__header">
      <h2 class="featured__title">{{ heading }}</h2>
      {%- if section.settings.show_view_all -%}
        <a class="featured__view-all" href="{{ featured.url }}">{{ 'sections.featured.view_all' | t }}</a>
      {%- endif -%}
    </div>

    <ul class="featured__track" role="list">
      {%- for product in featured.products limit: limit -%}
        <li class="featured__item">
          {% render 'product-card', product: product, show_quick_sizes: false %}
        </li>
      {%- endfor -%}
    </ul>
  </div>
{%- endif -%}

{% stylesheet %}
  .featured {
    margin-block: var(--space-2xl);
  }

  .featured__header {
    position: relative;
    display: flex;
    align-items: baseline;
    justify-content: center;
    margin-bottom: var(--space-lg);
  }

  .featured__title {
    font-size: var(--font-size-lg);
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .featured__view-all {
    position: absolute;
    right: 0;
    font-size: var(--font-size-sm);
    text-decoration: underline;
  }

  .featured__track {
    display: flex;
    gap: var(--space-sm);
    margin: 0;
    padding: 0 0 var(--space-sm);
    list-style: none;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
  }

  .featured__item {
    flex: 0 0 44%;
    scroll-snap-align: start;
  }

  @media (min-width: 750px) {
    .featured__item {
      flex-basis: 23.5%;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.featured_collection",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "t:labels.collection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "t:labels.max_products",
      "min": 4,
      "max": 16,
      "step": 1,
      "default": 8
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "t:labels.show_view_all",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "t:general.featured_collection"
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
